# SMTP Hostinger — usado para envio dos formulários do site
# Configure no Amplify Console > Environment variables
SMTP_USER=comercial@sisteq.com.br
SMTP_PASS=sua_senha_aqui

# ASAAS — gateway de pagamentos
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=sua_chave_asaas_aqui
# Token para validar webhooks (gerado por você, configurar igual no painel ASAAS)
ASAAS_WEBHOOK_TOKEN=seu_token_webhook_aqui
