NEXT_PUBLIC_SITE_URL=https://www.sisteq.com.br
NEXT_PUBLIC_APP_URL=https://app.sisteq.com.br

# Clerk is optional. Leave these blank to keep /login and /cadastro
# redirecting to the app URLs instead of rendering Clerk components.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_PATH=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_PATH=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=https://app.sisteq.com.br/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=https://app.sisteq.com.br/
